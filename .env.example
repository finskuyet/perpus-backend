# ============================================================
# ENVIRONMENT VARIABLES — Backend Perpustakaan
# Isi variabel ini di Railway/Render/Fly.io dashboard
# ============================================================

# Supabase PostgreSQL Connection String
# Dapatkan dari: Supabase > Project Settings > Database > Connection String (URI)
# Format: postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# JWT Secret — ganti dengan string acak yang kuat!
JWT_SECRET=ganti_dengan_string_rahasia_yang_panjang_dan_acak_2026

# Port (Railway/Render mengisi ini otomatis)
PORT=3001

# URL Frontend Netlify (isi setelah deploy frontend)
# Contoh: https://perpustakaan-anda.netlify.app
FRONTEND_URL=https://your-app.netlify.app
